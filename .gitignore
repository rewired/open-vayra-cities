# Dependencies
node_modules/

# Package manager
.pnpm-store/

# Build output
dist/
build/
coverage/
.vite/

# TypeScript
*.tsbuildinfo

# Compiler output and test output artifacts.
apps/*/tsc_output*.txt
**/tsc_output*.txt
**/typecheck_output*.txt
**/test_output*.txt

# Environment
.env
.env.*
!.env.example

# LLM docs
/docs/slices/**
!docs/slices/.gitkeep

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Runtime and generated data
data/generated/
data/runtime/

# Local databases
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal
*.sqlite3-journal

# Local save / cache / temp artifacts
*.tmp
*.temp
.cache/
tmp/
temp/

# Optional map or import artifacts that should stay local unless explicitly curated
*.mbtiles
*.gpkg

# Downloaded PBF files and checksums
data/osm/*.pbf
data/osm/**/*.pbf
data/osm/*.pbf.md5
data/osm/**/*.pbf.md5
!data/osm/.gitkeep

# Local OSRM routing artifacts
data/routing/osrm/**
!data/routing/osrm/.gitkeep

# Generated download helper HTML
data/generated/download-helpers/*.html

# Browser generated runtime assets
apps/web/public/generated/**
!apps/web/public/generated/.gitkeep
!apps/web/public/generated/scenarios/.gitkeep