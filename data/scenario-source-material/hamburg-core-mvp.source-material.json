{
  "schemaVersion": 1,
  "scenarioId": "hamburg-core-mvp",
  "manifestId": "hamburg-core-mvp-source-material",
  "description": "Source-material manifest for the baseline Hamburg scenario demand generation workflow.",
  "sources": [
    {
      "id": "hamburg-core-mvp-manual-seed",
      "kind": "manual-seed",
      "label": "Curated baseline demand seed",
      "path": "data/scenario-demand/hamburg-core-mvp.seed.json",
      "enabled": false
    },
    {
      "id": "hamburg-core-mvp-residential-grid-fixture",
      "kind": "census-grid",
      "label": "Hamburg Core MVP Residential Grid Fixture",
      "path": "data/scenario-source-material/fixtures/hamburg-core-mvp/residential-grid.fixture.csv",
      "adapter": "census-grid-csv",
      "enabled": true,
      "options": {
        "idColumn": "grid_id",
        "longitudeColumn": "lng",
        "latitudeColumn": "lat",
        "populationColumn": "population"
      }
    },
    {
      "id": "hamburg-core-mvp-workplace-attractors-fixture",
      "kind": "workplace-attractors",
      "label": "Hamburg Core MVP Workplace Attractors Fixture",
      "path": "data/scenario-source-material/fixtures/hamburg-core-mvp/workplace-attractors.fixture.geojson",
      "adapter": "workplace-attractor-geojson",
      "enabled": true,
      "options": {
        "idProperty": "id",
        "labelProperty": "name",
        "weightProperty": "weight",
        "scaleProperty": "scale",
        "defaultWeight": 100,
        "defaultScale": "district"
      }
    },
    {
      "id": "future-osm-extract",
      "kind": "osm-extract",
      "label": "Future local OSM extract source material",
      "expectedPath": "data/osm/...",
      "enabled": false,
      "notes": "Reserved for a later generic OSM attractor adapter."
    }
  ],
  "output": {
    "demandArtifactPath": "apps/web/public/generated/scenarios/hamburg-core-mvp.demand.json"
  }
}
